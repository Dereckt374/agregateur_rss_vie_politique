# Clé API Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Modèle Mistral à utiliser (mistral-small-latest recommandé pour le coût)
MISTRAL_MODEL=mistral-small-latest

# Identifiants Gmail pour l'envoi
# Utiliser un "mot de passe d'application" Google, pas votre mot de passe habituel
# (Compte Google > Sécurité > Mots de passe des applications)
SMTP_USER=votre.adresse@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Adresse expéditrice (en général = SMTP_USER)
EMAIL_FROM=votre.adresse@gmail.com

# Adresse destinataire du résumé hebdomadaire
EMAIL_TO=votre.adresse@gmail.com
